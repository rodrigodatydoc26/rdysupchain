# Desativa cache do navegador para SW e HTML — sempre busca versão fresca
<FilesMatch "^sw\.js$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
</FilesMatch>

<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
</FilesMatch>

# CSS/JS/imagens com query string de versão podem ser cacheados normalmente
<FilesMatch "\.(css|js|png|ico|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000"
</FilesMatch>

# Habilita compressão gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
